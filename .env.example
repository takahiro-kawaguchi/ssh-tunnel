# --- リモートサーバー設定 ---
SSH_USER=your_remote_user
SSH_HOST=remote-server.example.com
SSH_PORT=22

# ssh_keyフォルダの中にあるファイル名を指定してください
# 例: id_rsa, id_ed25519 など
IDENTITY_FILE=id_ed25519

# --- トンネル設定 (使うものだけ設定) ---
# ローカルフォワード (-L): コンテナのポートをリモート経由で指定ホスト:ポートへ接続
# 形式: ローカルポート:転送先ホスト:転送先ポート (カンマ区切りで複数可)
#LOCAL_TUNNELS=8080:internal-host:80

# リモートフォワード (-R): リモートサーバーのポートをローカルに引き込む
# 形式: リモートポート:転送先ホスト:転送先ポート (カンマ区切りで複数可)
#REMOTE_TUNNELS=19000:localhost:8050

# ダイナミックフォワード (-D): SOCKSプロキシ
#DYNAMIC_PORT=1080
